# Backend Environment Variables
# Copy this file to .env and fill in your API keys

# Server
PORT=3000

# VirusTotal API (free: 4 requests/min)
# Get your key at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your_virustotal_key_here

# Google Safe Browsing API (free)
# Get your key at: https://developers.google.com/safe-browsing
GOOGLE_SAFE_BROWSING_KEY=your_google_safe_browsing_key_here
